generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Clientes {
  id    Int    @id @default(autoincrement())
  nome  String
  cpf   String
  email String
  cnh   String
}

model Carros {
  id     Int    @id @default(autoincrement())
  placa  String @unique
  modelo String
  marca  String
  ano    Int
}
