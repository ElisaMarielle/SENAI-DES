generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuarios {
  id            Int          @id @default(autoincrement())
  nome          String
  email         String       @unique
  senha         String
  data_cadastro DateTime     @default(now()) //pega a data e hora do servidor.
  //não precisa passar a data e a hora, o backend preenche direto
  inscricoes    Inscricoes[]
}

model Imagem {
  id           Int      @id @default(autoincrement())
  nomeOriginal String
  nomeArquivo  String
  mimeType     String
  path         String
  data         DateTime @default(now())
  evento       Evento  @relation(fields: [eventoId], references: [id])
  eventoId     Int
}

model Evento {
  id                Int          @id @default(autoincrement())
  titulo            String
  descricao         String
  data_evento       DateTime
  local             String
  capacidade_maxima Int
  status            StatusEvento @default(ATIVO)

  inscricoes Inscricoes[]
  imagens    Imagem[]
}

model Inscricoes {
  id             Int              @id @default(autoincrement())
  data_inscricao DateTime         @default(now())
  status         StatusInscricoes @default(CONFIRMADA)
  evento         Evento           @relation(fields: [eventoId], references: [id])
  eventoId       Int
  usuarios       Usuarios         @relation(fields: [usuariosId], references: [id])
  usuariosId     Int
}

enum StatusEvento {
  ATIVO
  CANCELADO
  ENCERRADO
}

enum StatusInscricoes {
  CONFIRMADA
  LISTA_ESPERA
  CANCELADA
}
